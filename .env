# HoverGist SDK Configuration
# Copy this file to .env.local and fill in your values.

# Your HoverGist API key (get one from the HoverGist backend)
NEXT_PUBLIC_HOVERGIST_API_KEY=hg_your_key_here

# URL where your HoverGist backend is running
NEXT_PUBLIC_HOVERGIST_BACKEND_URL=http://localhost:3001

# PostgreSQL Database Connection String
# Example: postgresql://postgres:postgres@localhost:5432/animx
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

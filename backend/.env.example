# ==============================
# HoverGist Backend — Environment
# ==============================
# Copy this file to .env and fill in your OpenAI API key

OPENAI_API_KEY=sk-your-openai-key-here

PORT=3001
RATE_LIMIT=200
RATE_WINDOW_MS=86400000

# gpt-4o-mini is fast, cheap, and great for summarization
# Other options: gpt-4o, gpt-4-turbo, gpt-4
OPENAI_MODEL=gpt-4o-mini
GIST_MAX_TOKENS=200
ALLOWED_ORIGINS=*

# --- Azure OpenAI Optional Config ---
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=your-gpt4-deployment-name
# AZURE_OPENAI_API_VERSION=2024-02-15-preview
